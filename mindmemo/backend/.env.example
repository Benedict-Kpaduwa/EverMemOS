# Copy this file to .env and fill in your values

# OpenRouter API key (https://openrouter.ai) — supports GPT-4o-mini, Claude, etc.
OPENAI_API_KEY=your_openrouter_key_here

# OpenRouter base URL (default shown — do not change unless using plain OpenAI)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# EverMemOS local backend URL
EVERMEMOS_URL=http://localhost:1995
